# Backend API base URL (no trailing slash).
# When set, auth and dashboard data will be fetched from the backend.
# Example: http://localhost:8000 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Google Gemini API key for the in-app chatbot (get one at https://aistudio.google.com/apikey).
# Optional; the chat shows an error if unset.
GEMINI_API_KEY=
