# Backend API base URL (no trailing slash).
# When set, auth, dashboard data, and the StraitWatch Assistant (chat + voice) use the backend.
# Example: http://localhost:8000 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Chat and voice (TTS) for the assistant are provided by the backend when NEXT_PUBLIC_API_URL is set.
# Configure GEMINI_API_KEY, ELEVENLABS_API_KEY, and ELEVENLABS_VOICE_ID in Backend/.env (see Backend/.env.example).
